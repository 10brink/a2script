# SMTP configuration for sending daily Ann Arbor events digest
# Copy this file to .env and fill in your values

# Set to false to disable daily emails
EMAIL_ENABLED=true

# Set to true to send email regardless of location
FORCE_SEND=false

# Gmail SMTP settings (default)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address
SMTP_USER=your.email@gmail.com

# App-specific password (NOT your regular Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Email addresses
FROM_EMAIL=your.email@gmail.com
# Comma-separated for multiple recipients
TO_EMAIL=your.email@gmail.com, another@example.com
